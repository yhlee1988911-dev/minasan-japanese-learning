{
  "name": "baiduminasan-japanese-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "server:start": "node server/index.js",
    "server:dev": "npm run build && MINASAN_SQLITE_PATH=.baidu/local.sqlite PORT=8788 node server/index.js",
    "data:import": "ruby scripts/import_ci.rb",
    "data:sentences": "ruby scripts/generate_sentences_11_50.rb",
    "d1:migrate:local": "wrangler d1 migrations apply minasan-learning-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply minasan-learning-db --remote"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "read-excel-file": "^9.2.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "wrangler": "^4.104.0"
  }
}
