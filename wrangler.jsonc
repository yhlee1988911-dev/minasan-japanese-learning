{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "minasan-japanese-learning",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-24",
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
